# Application
NODE_ENV=development
PORT=3000

# PostgreSQL (docker-compose + Prisma)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=centerize_pms

# Prisma (uses same database)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/centerize_pms?schema=public"

# Opn Payments / Omise
OMISE_SECRET_KEY=skey_test_...
OMISE_PUBLIC_KEY=pkey_test_...
OMISE_WEBHOOK_SECRET=
