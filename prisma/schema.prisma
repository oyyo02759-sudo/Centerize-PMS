// Centerize PMS — Prisma schema (mirrors schema.sql / PostgreSQL 15+)
// Apply DDL via docker-compose init (schema.sql + seed.sql), then: npm run prisma:generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Domain enums (PostgreSQL native ENUM types)
// ---------------------------------------------------------------------------

enum RoomStatus {
  VACANT
  RESERVED
  OCCUPIED
  MAINTENANCE
  OUT_OF_SERVICE

  @@map("room_status")
}

enum LeaseStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  NOTICE_GIVEN
  TERMINATED
  CANCELLED

  @@map("lease_status")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  WRITTEN_OFF

  @@map("invoice_status")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  EXPIRED
  REFUNDED

  @@map("payment_status")
}

enum MaintenanceStatus {
  REPORTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("maintenance_status")
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY

  @@map("maintenance_priority")
}

enum ActorType {
  user
  system
  webhook

  @@map("actor_type")
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED

  @@map("webhook_event_status")
}

enum PaymentProvider {
  omise
  opn

  @@map("payment_provider")
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Organization {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String    @db.Citext
  name      String
  metadata  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  users                  User[]
  properties             Property[]
  tenants                Tenant[]
  leases                 Lease[]
  invoices               Invoice[]
  payments               Payment[]
  maintenanceTickets     MaintenanceTicket[]
  paymentWebhookEvents   PaymentWebhookEvent[]
  paymentLogs            PaymentLog[]
  auditLogs              AuditLog[]

  @@map("organizations")
}

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  email          String    @db.Citext
  displayName    String    @map("display_name")
  role           String    @default("STAFF")
  isActive       Boolean   @default(true) @map("is_active")
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization            Organization        @relation(fields: [organizationId], references: [id])
  maintenanceAssigned     MaintenanceTicket[] @relation("MaintenanceAssignedTo")
  maintenanceReported     MaintenanceTicket[] @relation("MaintenanceReportedBy")
  auditLogs               AuditLog[]

  @@index([organizationId])
  @@map("users")
}

model Property {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  code           String    @db.Citext
  name           String
  address        String?
  locationNotes  String?   @map("location_notes")
  gridRows       Int       @map("grid_rows")
  gridColumns    Int       @map("grid_columns")
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization         Organization        @relation(fields: [organizationId], references: [id])
  rooms                Room[]
  leases               Lease[]
  invoices             Invoice[]
  maintenanceTickets   MaintenanceTicket[]
  auditLogs            AuditLog[]

  @@index([organizationId])
  @@map("properties")
}

model Room {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  propertyId      String     @map("property_id") @db.Uuid
  roomNumber      String     @map("room_number")
  gridPositionRow Int        @map("grid_position_row")
  gridPositionCol Int        @map("grid_position_col")
  status          RoomStatus @default(VACANT)
  isActiveCell    Boolean    @default(true) @map("is_active_cell")
  label           String?
  metadata        Json       @default("{}")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?  @map("deleted_at") @db.Timestamptz(6)

  property           Property            @relation(fields: [propertyId], references: [id])
  leases             Lease[]
  invoices           Invoice[]
  maintenanceTickets MaintenanceTicket[]

  @@index([propertyId])
  @@index([propertyId, status])
  @@map("rooms")
}

model Tenant {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  fullName       String    @map("full_name")
  phone          String?
  email          String?   @db.Citext
  nationalId     String?   @map("national_id")
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization   Organization  @relation(fields: [organizationId], references: [id])
  primaryLeases  Lease[]       @relation("LeasePrimaryTenant")
  leaseTenants   LeaseTenant[]
  invoices       Invoice[]

  @@index([organizationId])
  @@map("tenants")
}

model Lease {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String      @map("organization_id") @db.Uuid
  propertyId      String      @map("property_id") @db.Uuid
  roomId          String      @map("room_id") @db.Uuid
  primaryTenantId String      @map("primary_tenant_id") @db.Uuid
  status          LeaseStatus @default(DRAFT)
  leaseNumber     String?     @map("lease_number")
  monthlyRent     Decimal     @map("monthly_rent") @db.Decimal(12, 2)
  currency        String      @default("THB") @db.Char(3)
  startDate       DateTime?   @map("start_date") @db.Date
  endDate         DateTime?   @map("end_date") @db.Date
  noticeGivenAt   DateTime?   @map("notice_given_at") @db.Timestamptz(6)
  activatedAt     DateTime?   @map("activated_at") @db.Timestamptz(6)
  terminatedAt    DateTime?   @map("terminated_at") @db.Timestamptz(6)
  cancelledAt     DateTime?   @map("cancelled_at") @db.Timestamptz(6)
  metadata        Json        @default("{}")
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?   @map("deleted_at") @db.Timestamptz(6)

  organization  Organization  @relation(fields: [organizationId], references: [id])
  property      Property      @relation(fields: [propertyId], references: [id])
  room          Room          @relation(fields: [roomId], references: [id])
  primaryTenant Tenant        @relation("LeasePrimaryTenant", fields: [primaryTenantId], references: [id])
  leaseTenants  LeaseTenant[]
  invoices      Invoice[]

  @@index([propertyId])
  @@index([roomId])
  @@index([primaryTenantId])
  @@index([status])
  @@map("leases")
}

model LeaseTenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leaseId   String   @map("lease_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  lease  Lease  @relation(fields: [leaseId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([leaseId, tenantId])
  @@index([tenantId])
  @@map("lease_tenants")
}

model Invoice {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  propertyId     String        @map("property_id") @db.Uuid
  leaseId        String?       @map("lease_id") @db.Uuid
  roomId         String?       @map("room_id") @db.Uuid
  tenantId       String?       @map("tenant_id") @db.Uuid
  invoiceNumber  String        @map("invoice_number")
  status         InvoiceStatus @default(DRAFT)
  currency       String        @default("THB") @db.Char(3)
  subtotalAmount Decimal       @default(0) @map("subtotal_amount") @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount    Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  amountPaid     Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  dueDate        DateTime?     @map("due_date") @db.Date
  issuedAt       DateTime?     @map("issued_at") @db.Timestamptz(6)
  paidAt         DateTime?     @map("paid_at") @db.Timestamptz(6)
  voidedAt       DateTime?     @map("voided_at") @db.Timestamptz(6)
  writtenOffAt   DateTime?     @map("written_off_at") @db.Timestamptz(6)
  notes          String?
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz(6)

  organization        Organization         @relation(fields: [organizationId], references: [id])
  property            Property             @relation(fields: [propertyId], references: [id])
  lease               Lease?               @relation(fields: [leaseId], references: [id])
  room                Room?                @relation(fields: [roomId], references: [id])
  tenant              Tenant?              @relation(fields: [tenantId], references: [id])
  lines               InvoiceLine[]
  payments            Payment[]
  allocations         InvoiceAllocation[]
  paymentLogs         PaymentLog[]

  @@index([propertyId])
  @@index([leaseId])
  @@index([status, dueDate])
  @@map("invoices")
}

model InvoiceLine {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  lineNumber  Int      @map("line_number")
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal   Decimal  @map("line_total") @db.Decimal(12, 2)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([invoiceId, lineNumber])
  @@index([invoiceId])
  @@map("invoice_lines")
}

model Payment {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String          @map("organization_id") @db.Uuid
  invoiceId             String          @map("invoice_id") @db.Uuid
  status                PaymentStatus   @default(PENDING)
  provider              PaymentProvider
  amount                Decimal         @db.Decimal(12, 2)
  currency              String          @default("THB") @db.Char(3)
  idempotencyKey        String          @map("idempotency_key")
  providerChargeId      String?         @map("provider_charge_id")
  providerTransactionId String?         @map("provider_transaction_id")
  qrPayload             Json?           @map("qr_payload")
  providerMetadata      Json            @default("{}") @map("provider_metadata")
  expiresAt             DateTime?       @map("expires_at") @db.Timestamptz(6)
  succeededAt           DateTime?       @map("succeeded_at") @db.Timestamptz(6)
  failedAt              DateTime?       @map("failed_at") @db.Timestamptz(6)
  refundedAt            DateTime?       @map("refunded_at") @db.Timestamptz(6)
  failureReason         String?         @map("failure_reason")
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime?       @map("deleted_at") @db.Timestamptz(6)

  organization       Organization          @relation(fields: [organizationId], references: [id])
  invoice            Invoice               @relation(fields: [invoiceId], references: [id])
  allocations        InvoiceAllocation[]
  webhookEvents      PaymentWebhookEvent[]
  paymentLogs        PaymentLog[]

  @@unique([idempotencyKey])
  @@index([invoiceId])
  @@index([status])
  @@map("payments")
}

model InvoiceAllocation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentId   String   @map("payment_id") @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  allocatedAt DateTime @default(now()) @map("allocated_at") @db.Timestamptz(6)
  metadata    Json     @default("{}")

  payment Payment @relation(fields: [paymentId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([paymentId, invoiceId])
  @@index([invoiceId])
  @@map("invoice_allocations")
}

model PaymentWebhookEvent {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String?            @map("organization_id") @db.Uuid
  paymentId             String?            @map("payment_id") @db.Uuid
  provider              PaymentProvider
  providerEventId       String             @map("provider_event_id")
  providerTransactionId String?            @map("provider_transaction_id")
  eventType             String             @map("event_type")
  processingStatus      WebhookEventStatus @default(RECEIVED) @map("processing_status")
  signatureVerified     Boolean            @default(false) @map("signature_verified")
  rawPayload            Json               @map("raw_payload")
  errorMessage          String?            @map("error_message")
  receivedAt            DateTime           @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt           DateTime?          @map("processed_at") @db.Timestamptz(6)
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization? @relation(fields: [organizationId], references: [id])
  payment      Payment?      @relation(fields: [paymentId], references: [id])

  @@unique([provider, providerEventId])
  @@index([paymentId])
  @@index([processingStatus])
  @@map("payment_webhook_events")
}

model PaymentLog {
  id                    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentId             String           @map("payment_id") @db.Uuid
  invoiceId             String           @map("invoice_id") @db.Uuid
  organizationId        String           @map("organization_id") @db.Uuid
  logType               String           @map("log_type")
  fromStatus            PaymentStatus?   @map("from_status")
  toStatus              PaymentStatus?   @map("to_status")
  provider              PaymentProvider?
  providerEventId       String?          @map("provider_event_id")
  providerTransactionId String?          @map("provider_transaction_id")
  idempotencyKey        String?          @map("idempotency_key")
  amount                Decimal?         @db.Decimal(12, 2)
  message               String?
  metadata              Json             @default("{}")
  occurredAt            DateTime         @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  payment      Payment      @relation(fields: [paymentId], references: [id])
  invoice      Invoice      @relation(fields: [invoiceId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([paymentId])
  @@index([invoiceId])
  @@index([occurredAt(sort: Desc)])
  @@map("payment_logs")
}

model MaintenanceTicket {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  propertyId     String              @map("property_id") @db.Uuid
  roomId         String?             @map("room_id") @db.Uuid
  ticketNumber   String              @map("ticket_number")
  status         MaintenanceStatus   @default(REPORTED)
  priority       MaintenancePriority @default(MEDIUM)
  title          String
  description    String?
  reportedAt     DateTime            @default(now()) @map("reported_at") @db.Timestamptz(6)
  scheduledAt    DateTime?           @map("scheduled_at") @db.Timestamptz(6)
  startedAt      DateTime?           @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime?           @map("completed_at") @db.Timestamptz(6)
  cancelledAt    DateTime?           @map("cancelled_at") @db.Timestamptz(6)
  assignedToId   String?             @map("assigned_to") @db.Uuid
  reportedById   String?             @map("reported_by") @db.Uuid
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?           @map("deleted_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])
  room         Room?        @relation(fields: [roomId], references: [id])
  assignedTo   User?        @relation("MaintenanceAssignedTo", fields: [assignedToId], references: [id])
  reportedBy   User?        @relation("MaintenanceReportedBy", fields: [reportedById], references: [id])

  @@index([propertyId, status])
  @@index([roomId])
  @@map("maintenance_tickets")
}

model AuditLog {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  propertyId     String?   @map("property_id") @db.Uuid
  entityType     String    @map("entity_type")
  entityId       String    @map("entity_id") @db.Uuid
  action         String    @default("state.transition")
  fromState      String?   @map("from_state")
  toState        String?   @map("to_state")
  actorId        String?   @map("actor_id") @db.Uuid
  actorType      ActorType @map("actor_type")
  correlationId  String?   @map("correlation_id")
  metadata       Json      @default("{}")
  occurredAt     DateTime  @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization? @relation(fields: [organizationId], references: [id])
  property     Property?     @relation(fields: [propertyId], references: [id])
  actor        User?         @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([propertyId, occurredAt(sort: Desc)])
  @@index([organizationId, occurredAt(sort: Desc)])
  @@map("audit_logs")
}
